// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Inbound contact form submissions from the website.
model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  company   String?
  service   String?
  budget    String?
  message   String
  status    String   @default("new")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}

/// Newsletter subscribers collected from the website footer / inline forms.
model NewsletterSubscriber {
  id          String   @id @default(cuid())
  email       String   @unique
  source      String?
  active      Boolean  @default(true)
  subscribedAt DateTime @default(now())

  @@index([active])
}

/// Saved pricing estimates generated by the interactive pricing calculator.
model PricingRequest {
  id              String   @id @default(cuid())
  name            String
  email           String
  services        String   // JSON array as string
  websiteSize     String?
  seoPackage      String?
  aiIntegrations  String?
  hosting         String?
  branding        String?
  maintenance     String?
  estimatedPrice  Int      @default(0)
  createdAt       DateTime @default(now())

  @@index([createdAt])
}

/// Long-form editorial blog posts (marketing content).
model BlogPost {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  excerpt     String
  content     String
  category    String
  tags        String    // comma-separated
  coverImage  String?
  readingTime Int       @default(5)
  author      String
  published   Boolean   @default(false)
  featured    Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([published])
  @@index([featured])
  @@index([category])
  @@index([publishedAt])
}

/// Portfolio case studies / client projects.
model PortfolioProject {
  id           String   @id @default(cuid())
  slug         String   @unique
  title        String
  client       String?
  industry     String
  services     String   // comma-separated
  technologies String   // comma-separated
  overview     String
  outcomes     String   // JSON array as string
  beforeMetric String?
  afterMetric  String?
  coverImage   String?
  featured     Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@index([industry])
  @@index([featured])
}

/// Client testimonials / social proof quotes.
model Testimonial {
  id         String   @id @default(cuid())
  authorName String
  authorRole String
  company    String
  content    String
  rating     Int      @default(5)
  industry   String
  service    String
  featured   Boolean  @default(false)
  approved   Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@index([featured])
  @@index([industry])
}

/// Service catalogue used to power the services section and pricing calculator.
model Service {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  shortDesc   String
  description String
  icon        String
  features    String   // comma-separated
  order       Int      @default(0)
  featured    Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([order])
  @@index([featured])
}

/// Industry verticals the agency serves.
model Industry {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String
  icon        String
  order       Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([order])
}
